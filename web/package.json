{
  "name": "@automo/web",
  "private": true,
  "type": "module",
  "description": "AUTOMO — the local-first browser AI agent (React + Tailwind, bundled by Bun to a static Pages site)",
  "scripts": {
    "gen:skills": "bun run ./gen-skills-index.ts",
    "predev": "bun run ./gen-skills-index.ts",
    "dev": "bun ./index.html",
    "build": "bun run ./build.ts",
    "test": "bun test tests/unit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:all": "bun run test && bun run test:e2e",
    "codegen": "playwright codegen http://localhost:4173",
    "smoke:build": "bun run ./tests/smoke/build-smoke.ts",
    "preview": "bun run ./tests/preview.ts"
  },
  "dependencies": {
    "@ai-sdk/react": "^4.0.32",
    "@automo/inference": "workspace:*",
    "@huggingface/transformers": "^3.0.0",
    "@mlc-ai/web-llm": "^0.2.84",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/agents": "^0.13.4",
    "@openai/agents-core": "^0.13.4",
    "@openai/agents-extensions": "^0.13.4",
    "@openai/agents-realtime": "^0.13.4",
    "ai": "^7.0.29",
    "buffer": "^6.0.3",
    "cron-schedule": "^6.0.0",
    "fflate": "^0.8.2",
    "isomorphic-git": "^1.38.5",
    "just-bash": "^3.0.2",
    "kokoro-js": "^1.2.1",
    "openai": "^6.47.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sql.js": "^1.14.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "bun-plugin-tailwind": "^0.0.15",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.6.0"
  }
}
